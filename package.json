{
  "name": "qa-playwright-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "QA Shop — pet project for manual + automation QA portfolio",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @qa-shop/web",
    "dev:api": "npm run dev -w @qa-shop/api",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build -w @qa-shop/api && npm run build -w @qa-shop/web",
    "test": "playwright test",
    "test:e2e": "playwright test --project=chromium",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "UPDATE_VISUAL_HASHES=1 playwright test --project=visual --update-snapshots",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:allure": "playwright test && npm run allure:generate",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "allure-commandline": "^2.34.0",
    "allure-playwright": "^3.2.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "imghash": "^1.1.0",
    "typescript-eslint": "^8.18.2"
  },
  "engines": {
    "node": ">=20"
  }
}
